---
import TemplateNav from '../components/TemplateNav.tsx';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notaría de San Ramón – Lic. Marcela Medina Ricci | Fe Pública y Certeza Jurídica</title>
  <meta name="description" content="Notaría de San Ramón a cargo de la Lic. Marcela Medina Ricci. Escrituras, testamentos, poderes y certificaciones. Av. Sta. Rosa Nº 7955, San Ramón." />
  <meta name="keywords" content="notaría, San Ramón, Marcela Medina Ricci, escrituras públicas, testamentos, poderes notariales, certificaciones, fe pública" />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Notaría de San Ramón – Lic. Marcela Medina Ricci" />
  <meta property="og:description" content="Fe pública con distinción en San Ramón. Lic. Marcela Medina Ricci, Notaria Pública." />
  <meta property="og:url" content="https://www.notariasanramon.cl/" />
  <link rel="canonical" href="https://www.notariasanramon.cl/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "LegalService",
    "name": "Notaría de San Ramón",
    "description": "Notaría pública a cargo de la Lic. Marcela Medina Ricci",
    "url": "https://www.notariasanramon.cl",
    "telephone": ["2-2511 4689","2-2615 0414"],
    "email": "notariasanramon@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av. Sta. Rosa Nº 7955",
      "addressLocality": "San Ramón",
      "addressCountry": "CL"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "17:30"
    },
    "employee": {
      "@type": "Person",
      "name": "Lic. Marcela Medina Ricci",
      "jobTitle": "Notaria Pública"
    }
  }</script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:      #FAF6F3;
      --cream-deep: #F2EAE4;
      --border:     #DDD0CA;
      --ink:        #1C1214;
      --ink-soft:   #3A2A2E;
      --sage:       #7A9E8C;
      --sage-light: #A8C4B8;
      --sage-pale:  #EBF3EF;
      --blush:      #C4908A;
      --blush-light:#DDB8B4;
      --blush-pale: #F5EDEB;
      --muted:      #8A7070;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: 'Jost', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.8;
      overflow-x: hidden;
    }

    /* ══════════════════════════════════════
       MASTHEAD — newspaper broadsheet header
       Replaces a conventional hero+nav combo.
       UNIQUE: nothing like T1/T2/T3 hero structures.
    ══════════════════════════════════════ */
    .masthead {
      border-bottom: 3px double var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--cream);
      transition: box-shadow 0.3s;
    }
    .masthead.scrolled { box-shadow: 0 2px 20px rgba(28,18,20,0.08); }

    /* dateline / meta bar */
    .masthead-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.45rem 3rem;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .masthead-meta-left,
    .masthead-meta-right {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .meta-item {
      font-family: 'Jost', sans-serif;
      font-size: 0.54rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .meta-item a { color: var(--blush); text-decoration: none; }
    .meta-item strong { color: var(--ink); font-weight: 400; }
    .meta-sep { color: var(--border); }

    /* title block */
    .masthead-title-block {
      text-align: center;
      padding: 1.2rem 3rem 1rem;
      position: relative;
    }
    .masthead-title-block::before {
      content: '';
      position: absolute;
      top: 0; left: 3rem; right: 3rem;
      height: 1px;
      background: var(--border);
    }
    .masthead-ornament {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 0.6rem;
    }
    .ornament-line { flex: 1; max-width: 120px; height: 1px; background: var(--border); }
    .ornament-center {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.65rem;
      color: var(--blush);
      letter-spacing: 0.3em;
    }
    .masthead-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(2rem, 5.5vw, 4.8rem);
      font-weight: 700;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 0.95;
    }
    .masthead-title em {
      color: var(--blush);
      font-style: italic;
      font-weight: 400;
    }
    .masthead-subtitle {
      font-family: 'Jost', sans-serif;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.5rem;
    }

    /* navigation below title */
    .masthead-nav {
      display: flex;
      justify-content: center;
      gap: 0;
      border-top: 1px solid var(--border);
      margin-top: 0.8rem;
    }
    .masthead-nav a {
      font-family: 'Jost', sans-serif;
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      padding: 0.65rem 2rem;
      border-right: 1px solid var(--border);
      transition: color 0.2s, background 0.2s;
    }
    .masthead-nav a:first-child { border-left: 1px solid var(--border); }
    .masthead-nav a:hover { color: var(--ink); background: var(--cream-deep); }
    .masthead-nav a.cta {
      background: var(--sage);
      color: white;
      border-color: var(--sage);
    }
    .masthead-nav a.cta:hover { background: var(--ink); border-color: var(--ink); }

    /* ══════════════════════════════════════
       BROADSHEET GRID — 3-column newspaper front page
       Left: services index, Center: main lead, Right: contact sidebar
       UNIQUE: no template uses this 3-col editorial-newspaper layout
    ══════════════════════════════════════ */
    .broadsheet {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      border-bottom: 2px solid var(--border);
      max-width: 100%;
    }
    .bs-col {
      padding: 2.5rem 2.5rem;
      border-right: 1px solid var(--border);
    }
    .bs-col:last-child { border-right: none; }
    .bs-col-title {
      font-family: 'Jost', sans-serif;
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--sage);
      padding-bottom: 0.6rem;
      border-bottom: 2px solid var(--sage);
      margin-bottom: 1.5rem;
      display: block;
    }

    /* left col: services index */
    .bs-index-list { list-style: none; }
    .bs-index-list li {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.88rem;
      font-weight: 400;
      color: var(--ink-soft);
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      gap: 0.8rem;
    }
    .bs-index-list li:last-child { border-bottom: none; }
    .bs-index-num {
      font-family: 'Jost', sans-serif;
      font-size: 0.6rem;
      color: var(--blush);
      flex-shrink: 0;
    }

    /* center col: main lead story */
    .bs-lead-overline {
      font-family: 'Jost', sans-serif;
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--blush);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }
    .bs-lead-overline::before { content: ''; width: 24px; height: 1px; background: var(--blush); }
    .bs-lead-h1 {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(1.7rem, 3.2vw, 3rem);
      font-weight: 700;
      color: var(--ink);
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin-bottom: 1.2rem;
    }
    .bs-lead-h1 em { color: var(--sage); font-weight: 400; font-style: italic; }
    .bs-rule { width: 40px; height: 2px; background: var(--blush); margin: 1.2rem 0; }
    .bs-lead-body {
      font-family: 'Jost', sans-serif;
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.9;
      margin-bottom: 2rem;
    }
    .bs-lead-body strong { color: var(--ink); font-weight: 400; }
    .bs-cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .bs-btn-primary {
      display: inline-block;
      background: var(--sage);
      color: white;
      padding: 0.8rem 2rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.25s;
    }
    .bs-btn-primary:hover { background: var(--ink); }
    .bs-btn-secondary {
      display: inline-block;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0.8rem 1.8rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.25s;
    }
    .bs-btn-secondary:hover { border-color: var(--ink); color: var(--ink); }

    /* right col: contact sidebar */
    .bs-contact-item { margin-bottom: 1.4rem; }
    .bs-contact-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--blush);
      margin-bottom: 0.3rem;
    }
    .bs-contact-value {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.88rem;
      color: var(--ink-soft);
      line-height: 1.5;
    }
    .bs-contact-value a { color: var(--sage); text-decoration: none; }
    .bs-hours-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      border: 1px solid var(--border);
      margin-top: 1.5rem;
    }
    .bs-hours-row {
      display: flex;
      justify-content: space-between;
      padding: 0.5rem 0.8rem;
      border-bottom: 1px solid var(--border);
      font-family: 'Jost', sans-serif;
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--muted);
    }
    .bs-hours-row:last-child { border-bottom: none; }
    .bs-hours-row strong { color: var(--sage); font-weight: 400; font-size: 0.7rem; }

    /* ══════════════════════════════════════
       SERVICES: 2 FEATURED + 4 GRID
       UNIQUE: no template uses this 2+4 layout pattern
    ══════════════════════════════════════ */
    .services {
      border-bottom: 1px solid var(--border);
    }
    .services-masthead {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 3rem 1.5rem;
      border-bottom: 2px solid var(--ink);
    }
    .sm-title {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: 0.04em;
    }
    .sm-desc {
      font-family: 'Jost', sans-serif;
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--muted);
      max-width: 380px;
      line-height: 1.6;
    }

    /* 2 featured services */
    .svc-featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--border);
    }
    .svc-feat-card {
      padding: 3rem;
      border-right: 1px solid var(--border);
      position: relative;
      transition: background 0.25s;
    }
    .svc-feat-card:last-child { border-right: none; }
    .svc-feat-card:hover { background: var(--blush-pale); }
    .svc-feat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--blush);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
    }
    .svc-feat-card:hover::before { transform: scaleX(1); }
    .feat-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--blush);
      margin-bottom: 1rem;
    }
    .feat-title {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .feat-body {
      font-family: 'Jost', sans-serif;
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.8;
    }

    /* 4 secondary services */
    .svc-secondary {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .svc-sec-card {
      padding: 2rem 2rem;
      border-right: 1px solid var(--border);
      border-top: 2px solid var(--sage);
      transition: background 0.25s;
    }
    .svc-sec-card:last-child { border-right: none; }
    .svc-sec-card:hover { background: var(--sage-pale); }
    .sec-num {
      font-family: 'Jost', sans-serif;
      font-size: 0.58rem;
      letter-spacing: 0.3em;
      color: var(--sage);
      margin-bottom: 0.8rem;
      font-weight: 400;
    }
    .sec-title {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.6rem;
      line-height: 1.25;
    }
    .sec-body {
      font-family: 'Jost', sans-serif;
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.7;
    }

    /* ══════════════════════════════════════
       STATS STRIP — sage background
    ══════════════════════════════════════ */
    .stats-strip {
      background: var(--sage);
      padding: 2.5rem 3rem;
      display: flex;
      justify-content: center;
      gap: 0;
    }
    .strip-stat {
      flex: 1;
      max-width: 240px;
      text-align: center;
      padding: 0 2rem;
      border-right: 1px solid rgba(255,255,255,0.2);
    }
    .strip-stat:last-child { border-right: none; }
    .strip-num {
      font-family: 'Libre Baskerville', serif;
      font-size: 2.5rem;
      font-weight: 700;
      color: white;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .strip-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.65);
      font-weight: 400;
    }

    /* ══════════════════════════════════════
       ABOUT: BLUSH QUOTE + SAGE BIO — side by side full width panels
       UNIQUE: no template uses this horizontal tinted-panel split
    ══════════════════════════════════════ */
    .about {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 480px;
    }
    .about-quote-panel {
      background: var(--blush-pale);
      border-right: 1px solid var(--border);
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
    }
    .about-quote-panel::before {
      content: '"';
      position: absolute;
      top: 2rem; left: 3.5rem;
      font-family: 'Libre Baskerville', serif;
      font-size: 8rem;
      color: var(--blush);
      opacity: 0.18;
      line-height: 1;
    }
    .about-q-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--blush);
      margin-bottom: 1.5rem;
      font-weight: 400;
    }
    .about-q-text {
      font-family: 'Libre Baskerville', serif;
      font-style: italic;
      font-size: clamp(1.1rem, 2vw, 1.5rem);
      color: var(--ink-soft);
      line-height: 1.6;
      position: relative;
      z-index: 1;
    }
    .about-q-text em { font-style: normal; color: var(--blush); }
    .about-q-attr {
      margin-top: 2rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 400;
    }

    .about-bio-panel {
      background: var(--sage-pale);
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.5rem;
    }
    .about-b-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--sage);
      font-weight: 400;
    }
    .about-b-name {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.1;
    }
    .about-b-name em { color: var(--sage); font-style: italic; font-weight: 400; }
    .about-b-text {
      font-family: 'Jost', sans-serif;
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--ink-soft);
      line-height: 1.85;
    }
    .about-b-creds {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .about-b-creds li {
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      font-weight: 300;
      color: var(--ink-soft);
      padding: 0.55rem 0;
      border-bottom: 1px solid rgba(122,158,140,0.2);
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
    }
    .about-b-creds li:last-child { border-bottom: none; }
    .about-b-creds li::before { content: '·'; color: var(--sage); font-weight: 700; flex-shrink: 0; font-size: 1rem; line-height: 1.3; }

    /* ══════════════════════════════════════
       CONTACT: SINGLE CENTERED COLUMN
       No 2-col split, centered max-width form.
       Different from all 3 existing 2-col contacts.
    ══════════════════════════════════════ */
    .contact {
      padding: 6rem 2rem;
      background: var(--cream-deep);
      border-top: 1px solid var(--border);
    }
    .contact-inner {
      max-width: 620px;
      margin: 0 auto;
    }
    .contact-head {
      text-align: center;
      margin-bottom: 3rem;
    }
    .contact-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--sage);
      font-weight: 400;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 0.8rem;
    }
    .contact-label::before,
    .contact-label::after { content: ''; width: 20px; height: 1px; background: var(--sage); }
    .contact-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }
    .contact-sub {
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--muted);
      font-style: italic;
    }
    /* info pills row */
    .contact-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .contact-pill {
      background: white;
      border: 1px solid var(--border);
      padding: 0.45rem 1.1rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--ink-soft);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .pill-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--sage); flex-shrink: 0; }
    .pill-dot--blush { background: var(--blush); }

    /* form */
    .contact-form { display: flex; flex-direction: column; gap: 0; }
    .cf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 1.2rem; }
    .cf-group { margin-bottom: 1.2rem; }
    .cf-label {
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.4rem;
    }
    .cf-input,
    .cf-select,
    .cf-textarea {
      width: 100%;
      background: white;
      border: 1px solid var(--border);
      border-bottom: 2px solid var(--sage-light);
      padding: 0.7rem 0.9rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--ink);
      outline: none;
      transition: border-color 0.25s;
      border-radius: 0;
    }
    .cf-input:focus,
    .cf-select:focus,
    .cf-textarea:focus { border-bottom-color: var(--sage); background: var(--sage-pale); }
