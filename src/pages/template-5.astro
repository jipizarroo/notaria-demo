    .footer-legal { font-family: 'Jost', sans-serif; font-size: 0.54rem; letter-spacing: 0.14em; color: rgba(250,246,243,0.15); }
    .footer-links { display: flex; gap: 2rem; }
    .footer-links a {
      font-family: 'Jost', sans-serif;
      font-size: 0.54rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(250,246,243,0.2);
      text-decoration: none;
      transition: color 0.2s;
    }
