    .cf-submit {
      width: 100%;
      background: var(--sage);
      color: white;
      border: none;
      padding: 1rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.25s;
    }
    .cf-submit:hover { background: var(--ink); }

    /* ── FOOTER ── */
    footer {
      background: var(--ink);
      padding: 2.5rem 3rem;
    }
    .footer-inner {
      max-width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.5rem;
    }
