    /* animations */
    .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @keyframes mhReveal {
      from { opacity: 0; transform: translateY(-12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .masthead-title { animation: mhReveal 0.9s ease 0.1s both; }
    .masthead-subtitle { animation: mhReveal 0.8s ease 0.25s both; }

    /* ── HAMBURGER ── */
    .menu-btn {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 301;
    }
    .menu-btn span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: currentColor;
      transition: all 0.25s;
    }
    .menu-btn.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
    .menu-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .menu-btn.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

    @media (max-width: 768px) {
      /* masthead */
      .masthead-meta { padding: 0.4rem 1.2rem; flex-direction: column; align-items: center; gap: 0.3rem; }
      .masthead-meta-left, .masthead-meta-right { gap: 0.8rem; flex-wrap: wrap; justify-content: center; }
      .meta-sep { display: none; }
      .masthead-title-block { padding: 0.8rem 1.2rem 0.5rem; position: relative; }
      .masthead-title { font-size: clamp(1.6rem, 8vw, 3rem); letter-spacing: 0.04em; }
      .masthead-subtitle { font-size: 0.5rem; }
      .masthead-ornament { display: none; }
      /* hamburger in masthead */
      .masthead .menu-btn { display: flex; color: var(--ink); position: absolute; right: 1.2rem; top: 50%; transform: translateY(-50%); }
      #site-nav {
        display: none;
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(250,246,243,0.98); backdrop-filter: blur(24px);
        flex-direction: column; align-items: center; justify-content: center;
        gap: 2.5rem; z-index: 250;
      }
      #site-nav.open { display: flex; }
      #site-nav a { font-size: 1rem; letter-spacing: 0.22em; color: var(--ink) !important; border: none !important; background: none !important; padding: 0 !important; }
      /* broadsheet: stack columns */
      .broadsheet { grid-template-columns: 1fr; }
      .bs-col { border-right: none; border-bottom: 1px solid var(--border); padding: 2rem 1.5rem; }
      .bs-col:last-child { border-bottom: none; }
      .bs-lead-h1 { font-size: clamp(1.5rem, 7vw, 2.5rem); }
      /* services */
