---
import TemplateNav from '../components/TemplateNav.tsx';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notaría de San Ramón — Lic. Marcela Medina Ricci</title>
  <meta name="description" content="Notaría de San Ramón. Fe pública al servicio de su patrimonio. Escrituras, testamentos, poderes y certificaciones con rigor y distinción." />
  <meta property="og:title" content="Notaría de San Ramón — Lic. Marcela Medina Ricci" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://notariasanramon.cl" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"LegalService","name":"Notaría de San Ramón","address":{"@type":"PostalAddress","streetAddress":"Av. Sta. Rosa Nº 7955","addressLocality":"San Ramón","addressCountry":"CL"},"telephone":"2-2511 4689","email":"notariasanramon@gmail.com","openingHours":"Mo-Fr 09:00-17:30"}
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --void: #07080C;
      --void-mid: #0E1018;
      --void-light: #161820;
      --sage: #6E9A88;
      --sage-light: #92BBA8;
      --gold: #C8C090;
      --gold-dim: #A8A070;
      --cream: #EAE8E0;
      --cream-dim: #B8B4A8;
      --rule: rgba(110,154,136,0.2);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--void);
      color: var(--cream);
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.8rem 3rem;
      transition: background 0.4s, border-color 0.4s;
      border-bottom: 1px solid transparent;
    }
    header.scrolled {
      background: rgba(7,8,12,0.96);
      backdrop-filter: blur(16px);
      border-bottom-color: var(--rule);
    }
    .logo {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .logo-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 400;
      color: var(--cream);
      letter-spacing: 0.08em;
      line-height: 1;
    }
    .logo-name em { font-style: italic; color: var(--sage-light); }
    .logo-tag {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: rgba(110,154,136,0.5);
    }
    nav { display: flex; align-items: center; gap: 2.5rem; }
    nav a {
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(234,232,224,0.45);
      text-decoration: none;
      transition: color 0.25s;
    }
    nav a:hover { color: var(--sage-light); }
    .nav-cta {
      color: var(--sage) !important;
      border-bottom: 1px solid rgba(110,154,136,0.35);
      padding-bottom: 1px;
    }

    /* ── HERO — EDITORIAL ── */
    .hero {
      min-height: 100vh;
      display: flex;
      position: relative;
      overflow: hidden;
    }
    /* Vertical spine on left */
    .hero-spine {
      width: 64px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      border-right: 1px solid var(--rule);
      padding: 8rem 0;
      position: relative;
    }
    .hero-spine-text {
      font-family: 'Playfair Display', serif;
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: rgba(110,154,136,0.4);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
    }
    .hero-spine-dot {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--sage);
      opacity: 0.4;
      margin: 1.5rem 0;
    }
    /* Hero body */
    .hero-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 8rem 4rem 5rem 3rem;
      position: relative;
    }
    .hero-label {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .hero-label::before { content: ''; width: 32px; height: 1px; background: var(--sage); display: block; }
    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 8vw, 9rem);
      font-weight: 900;
      line-height: 0.9;
      color: var(--cream);
      margin-bottom: 3rem;
      letter-spacing: -0.03em;
    }
    h1 em {
      font-style: italic;
      font-weight: 400;
      color: var(--sage-light);
      display: block;
      font-size: 0.65em;
      letter-spacing: 0.01em;
    }
    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 4rem;
    }
    .hero-desc {
      font-size: 0.9rem;
      font-weight: 300;
      color: rgba(234,232,224,0.45);
      line-height: 1.9;
      max-width: 360px;
      letter-spacing: 0.02em;
    }
    .hero-cta-block { display: flex; flex-direction: column; gap: 1rem; align-items: flex-end; flex-shrink: 0; }
    .btn-sage {
      display: inline-block;
      padding: 1rem 2.5rem;
      background: transparent;
      border: 1px solid var(--sage);
      color: var(--sage-light);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: color 0.3s;
    }
    .btn-sage::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--sage);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
      z-index: -1;
    }
    .btn-sage:hover { color: var(--void); }
    .btn-sage:hover::before { transform: scaleX(1); }
    .hero-scroll-hint {
      font-size: 0.55rem;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: rgba(234,232,224,0.2);
    }
    /* Right accent column */
    .hero-right-col {
      width: 240px;
      flex-shrink: 0;
      border-left: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 8rem 2rem 5rem;
    }
    .hero-stats { display: flex; flex-direction: column; gap: 2.5rem; }
    .hstat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.8rem;
      font-weight: 700;
      color: var(--sage);
      line-height: 1;
    }
    .hstat-label {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(234,232,224,0.3);
      margin-top: 0.25rem;
    }
    .hstat-rule { width: 100%; height: 1px; background: var(--rule); }

    /* ── MARQUEE ── */
    .marquee { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); padding: 1.2rem 0; overflow: hidden; background: var(--void-mid); }
    .marquee-track { display: flex; gap: 4rem; width: max-content; animation: marquee 30s linear infinite; }
    .marquee-item { font-size: 0.58rem; letter-spacing: 0.5em; text-transform: uppercase; color: rgba(110,154,136,0.35); white-space: nowrap; display: flex; align-items: center; gap: 4rem; }
    .marquee-sep { width: 3px; height: 3px; border-radius: 50%; background: rgba(110,154,136,0.25); }
    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── SERVICES — ALTERNATING ROWS ── */
    .services { padding: 7rem 0; }
    .svc-header {
      display: flex;
      align-items: baseline;
      gap: 3rem;
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 3rem;
      margin-bottom: 4rem;
    }
    .svc-header-num {
      font-family: 'Playfair Display', serif;
      font-size: 0.7rem;
      color: rgba(110,154,136,0.4);
      letter-spacing: 0.25em;
    }
    h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3.5rem);
      font-weight: 700;
      color: var(--cream);
      line-height: 1.1;
    }
    h2 em { font-style: italic; font-weight: 400; color: var(--sage-light); }
    .svc-row {
      display: flex;
      align-items: stretch;
      border-top: 1px solid var(--rule);
      transition: background 0.3s;
      cursor: default;
    }
    .svc-row:last-child { border-bottom: 1px solid var(--rule); }
    .svc-row:hover { background: rgba(110,154,136,0.04); }
    .svc-row:hover .svc-row-num { color: var(--sage-light); }
    .svc-row-num {
      width: 120px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 2.5rem 3rem;
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      font-weight: 900;
      color: rgba(110,154,136,0.08);
      line-height: 1;
      transition: color 0.3s;
      border-right: 1px solid var(--rule);
    }
    .svc-row-content {
      flex: 1;
      padding: 2.5rem 3rem;
      display: flex;
      align-items: center;
      gap: 4rem;
    }
    .svc-row-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--cream);
      min-width: 220px;
      flex-shrink: 0;
    }
    .svc-row-desc {
      font-size: 0.85rem;
      font-weight: 300;
      color: rgba(234,232,224,0.38);
      line-height: 1.85;
      letter-spacing: 0.02em;
    }
    .svc-row-arrow {
      margin-left: auto;
      flex-shrink: 0;
      color: rgba(110,154,136,0);
      font-size: 1.2rem;
      transition: all 0.3s;
      padding-right: 3rem;
    }
    .svc-row:hover .svc-row-arrow { color: var(--sage); transform: translateX(6px); }

    /* ── ABOUT — EDITORIAL ── */
    .about {
      padding: 9rem 0;
      background: var(--void-mid);
      position: relative;
      overflow: hidden;
    }
    .about::before {
      content: '';
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 64px;
      border-right: 1px solid var(--rule);
    }
    .about-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 3rem 0 calc(64px + 3rem);
    }
    .about-eyebrow {
      font-size: 0.6rem;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 3rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .about-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--sage); }
    .about-quote {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 400;
      font-style: italic;
      color: var(--cream);
      line-height: 1.25;
      max-width: 900px;
      margin-bottom: 4rem;
    }
    .about-quote em { color: var(--sage-light); font-style: normal; }
    .about-bio-row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 3rem;
      padding-top: 3rem;
      border-top: 1px solid var(--rule);
    }
    .about-bio-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--cream);
      margin-bottom: 0.5rem;
    }
    .about-bio-role {
      font-size: 0.62rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--sage);
      opacity: 0.7;
    }
    .about-bio-text {
      font-size: 0.85rem;
      font-weight: 300;
      color: rgba(234,232,224,0.4);
      line-height: 1.9;
    }
    .about-contact-col { display: flex; flex-direction: column; gap: 1rem; }
    .about-contact-item { }
    .about-contact-label { font-size: 0.55rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--sage); opacity: 0.6; margin-bottom: 0.2rem; }
    .about-contact-val { font-size: 0.85rem; font-weight: 300; color: rgba(234,232,224,0.55); }

    /* ── CONTACT ── */
    .contact {
      padding: 7rem 0;
      background: var(--void-light);
      border-top: 1px solid var(--rule);
    }
    .contact-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 3rem 0 calc(64px + 3rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
    .contact-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.5rem, 4vw, 4rem);
      font-weight: 900;
      color: var(--cream);
      line-height: 1;
      margin-bottom: 3rem;
      letter-spacing: -0.02em;
    }
    .contact-heading em { font-style: italic; font-weight: 400; color: var(--sage-light); }
    .cinfo-item { margin-bottom: 2rem; }
    .cinfo-label { font-size: 0.55rem; letter-spacing: 0.45em; text-transform: uppercase; color: var(--sage); opacity: 0.6; margin-bottom: 0.3rem; }
    .cinfo-val { font-size: 0.9rem; font-weight: 300; color: rgba(234,232,224,0.55); line-height: 1.6; }
    .contact-form { display: flex; flex-direction: column; gap: 1.8rem; }
    .cf { display: flex; flex-direction: column; gap: 0.4rem; }
    .cf label { font-size: 0.55rem; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(110,154,136,0.5); }
    .cf input, .cf select, .cf textarea {
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(110,154,136,0.15);
      color: var(--cream-dim);
      padding: 0.7rem 0;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 300;
      outline: none;
      transition: border-color 0.3s;
    }
    .cf input:focus, .cf select:focus, .cf textarea:focus { border-bottom-color: rgba(110,154,136,0.5); }
    .cf textarea { resize: none; min-height: 80px; }
    .cf input::placeholder, .cf textarea::placeholder { color: rgba(234,232,224,0.15); }
    .cf select option { background: var(--void-light); }
    .cf-submit {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--sage);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      transition: gap 0.3s;
    }
    .cf-submit:hover { gap: 2.2rem; }
    .cf-submit-line { width: 36px; height: 1px; background: var(--sage); transition: width 0.3s; }
    .cf-submit:hover .cf-submit-line { width: 56px; }

    /* ── FOOTER ── */
    footer {
      background: var(--void);
      border-top: 1px solid var(--rule);
      padding: 2rem 0;
    }
    .footer-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 3rem 0 calc(64px + 3rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-name { font-family: 'Playfair Display', serif; font-size: 0.8rem; color: rgba(234,232,224,0.2); }
    .footer-legal { font-size: 0.6rem; letter-spacing: 0.12em; color: rgba(234,232,224,0.1); }

    /* ── ANIMATIONS ── */
    @keyframes t7In { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: translateY(0); } }
    .hero-label { animation: t7In 0.8s ease 0.2s forwards; opacity: 0; }
    h1 { animation: t7In 1s ease 0.4s forwards; opacity: 0; }
    .hero-bottom { animation: t7In 0.9s ease 0.7s forwards; opacity: 0; }
    .hero-right-col { animation: t7In 1s ease 0.5s forwards; opacity: 0; }

    /* ── HAMBURGER ── */
    .menu-btn {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 301;
    }
    .menu-btn span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: currentColor;
      transition: all 0.25s;
    }
    .menu-btn.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
    .menu-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .menu-btn.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

    @media (max-width: 768px) {
      .menu-btn { display: flex; color: var(--cream); }
      #hdr { padding: 1rem 1.5rem; }
      #site-nav {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(7,8,12,0.97); backdrop-filter: blur(24px);
        flex-direction: column; align-items: center; justify-content: center;
        gap: 2.5rem; display: none; z-index: 250;
      }
      #site-nav.open { display: flex; }
      #site-nav a { font-size: 1rem; letter-spacing: 0.22em; color: var(--cream) !important; }
      /* hero — uses display:flex not grid */
      .hero { flex-direction: column; min-height: auto; padding-top: 4.5rem; }
      .hero-spine { display: none; }
      .hero-body { padding: 2.5rem 1.5rem 1.5rem; }
      h1 { font-size: clamp(2.4rem, 10vw, 3.5rem); }
      .hero-bottom { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
      .hero-right-col {
        width: 100%; border-left: none;
        border-top: 1px solid rgba(110,154,136,0.15);
        padding: 1.5rem;
      }
      .hero-stats { flex-direction: row; justify-content: space-around; gap: 0; width: 100%; }
      .hstat-rule { width: 1px; height: 40px; margin: 0; }
      /* services — svc-row uses display:flex */
      .svc-row-num { width: 56px; padding: 1.5rem 1rem; font-size: 2rem; }
      .svc-row-content { padding: 1.5rem 1rem 1.5rem 0; flex-direction: column; gap: 0.4rem; align-items: flex-start; }
      .svc-row-name { min-width: unset; font-size: 1.1rem; }
      .svc-row-arrow { display: none; }
      /* about */
      .about::before { display: none; }
      .about-inner { padding: 0 1.5rem; }
      .about-quote { font-size: clamp(1.3rem, 5vw, 1.8rem); }
      .about-bio-row { grid-template-columns: 1fr; gap: 1.5rem; }
      /* contact */
      .contact-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
        padding: 0 1.5rem;
      }
      /* footer */
      .footer-inner {
        flex-direction: column; align-items: center;
        text-align: center; padding: 2rem 1.5rem; gap: 0.8rem;
      }
    }
  </style>
</head>
<body>
  <header id="hdr">
    <div class="logo">
      <div class="logo-name">Notaría <em>de San Ramón</em></div>
      <div class="logo-tag">Lic. Marcela Medina Ricci</div>
    </div>
    
      <button class="menu-btn" id="menu-btn" aria-label="Abrir menú" aria-expanded="false"><span></span><span></span><span></span></button>
      <nav id="site-nav">
      <a href="#servicios">Servicios</a>
      <a href="#nosotros">La Notaria</a>
      <a href="#contacto" class="nav-cta">Consulta</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-spine">
      <span class="hero-spine-text">Notaría de San Ramón</span>
      <div class="hero-spine-dot"></div>
      <span class="hero-spine-text">Fe Pública · Certeza</span>
    </div>
    <div class="hero-body">
      <p class="hero-label">Fe Pública · San Ramón</p>
      <h1>
        Certeza<br/>jurídica
        <em>sin concesiones.</em>
      </h1>
      <div class="hero-bottom">
        <p class="hero-desc">
          La Notaría de San Ramón ofrece el más alto rigor en cada instrumento notarial.
          Su patrimonio, sus acuerdos y su futuro merecen certeza absoluta.
        </p>
        <div class="hero-cta-block">
          <a href="#contacto" class="btn-sage">Solicitar Cita</a>
          <span class="hero-scroll-hint">Desplazar para explorar</span>
        </div>
      </div>
    </div>
    <div class="hero-right-col">
      <div class="hero-stats">
        <div>
          <div class="hstat-num">+20</div>
          <div class="hstat-label">Años de ejercicio</div>
        </div>
        <div class="hstat-rule"></div>
        <div>
          <div class="hstat-num">6</div>
          <div class="hstat-label">Especialidades</div>
        </div>
        <div class="hstat-rule"></div>
        <div>
          <div class="hstat-num">100%</div>
          <div class="hstat-label">Fe pública</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
